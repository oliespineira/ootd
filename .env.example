PORT=8787

# If set, signups will be appended to an Excel Table via Microsoft Graph.
# You need an Entra ID app registration with application permissions:
# - Files.ReadWrite.All (or Sites.ReadWrite.All if SharePoint)
# Then grant admin consent.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Where the Excel file lives (OneDrive/SharePoint)
EXCEL_DRIVE_ID=
EXCEL_ITEM_ID=

# Name of the Excel "Table" (not sheet name). Example: Table1
EXCEL_TABLE_NAME=

